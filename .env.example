# 飞书开放平台 - 企业自建应用凭证
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# 飞书开放平台 - 事件订阅配置
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=xxx

# Obsidian vault 路径
VAULT_PATH=D:/brain

# 服务端口
PORT=3000

# 飞书知识库 Space ID（可选，@同步wiki 时使用）
WIKI_SPACE_ID=

# DeepSeek API（用于 AI 整理和摘要功能）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：每天自动整理 daily，格式 HH:MM。留空则只在发送 /整理 时运行
AUTO_ORGANIZE_TIME=
